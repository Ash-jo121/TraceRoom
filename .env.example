LLM_API_KEY="your-api-key-here"
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

LLM_PROVIDER=openai
LLM_INPUT_COST_PER_1M_USD=0
LLM_CACHED_INPUT_COST_PER_1M_USD=0
LLM_OUTPUT_COST_PER_1M_USD=0
LLM_PRICING_VERSION=2026-07-21

# Snapshot Forge numeric authority. Required for non-INFY symbols.
TWELVE_DATA_API_KEY=your-twelve-data-api-key
SNAPSHOT_MAX_AGE_HOURS=72

# Snapshot Forge context research. Keep separate from the debate LLM key.
OPENAI_API_KEY=your-openai-api-key
OPENAI_SEARCH_MODEL=gpt-5.4-nano
SESSION_COST_ALERT_THRESHOLD_USD=0.10

PORT=8787
TRACEROOM_DB_PATH=data/traceroom.sqlite
SIGNOZ_BASE_URL=http://localhost:8080
SIGNOZ_MCP_URL=http://localhost:8000/mcp
SIGNOZ_MCP_TIMEOUT_MS=2500
# Optional when credentials are not already configured on the MCP server:
# SIGNOZ_API_KEY=your-signoz-api-key
